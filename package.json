{
  "name": "pushengage-api-tests",
  "version": "1.0.0",
  "description": "Automated API testing suite for PushEngage REST APIs",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:specific": "vitest run --reporter=verbose",
    "test:connection": "node test-connection.js",
    "test:subscribers": "vitest run tests/subscribers.test.js --reporter=verbose",
    "test:notifications": "vitest run tests/notifications.test.js --reporter=verbose",
    "test:campaigns": "vitest run tests/campaigns.test.js --reporter=verbose",
    "test:integration": "vitest run tests/integration.test.js --reporter=verbose"
  },
  "keywords": [
    "pushengage",
    "api-testing",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  }
}
